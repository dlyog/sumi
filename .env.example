# Local OpenAI-compatible model server. Copy to .env and set values for this host.
LLM_PROVIDER=local
LLM_BASE_URL=http://127.0.0.1:8888/v1
LLM_MODEL=replace-with-the-loaded-local-model
LLM_API_KEY=local
LLM_TIMEOUT_SECONDS=60

# Local circuit simulator used when the UI first opens.
QLAB_BACKEND=qiskit

# Local Apple-Silicon Whisper transcription for the learning companion.
WHISPER_MODEL=mlx-community/whisper-small-mlx
WHISPER_MAX_SECONDS=30

# Created automatically by scripts/setup-postgres.sh for local development.
DATABASE_URL=postgresql://quantumyog:replace-with-local-db-password@127.0.0.1:5432/quantumyog

# URLs/ports used by the optional ChatGPT and scheduled-improvement services.
PUBLIC_APP_URL=http://localhost:8080
MCP_HOST=127.0.0.1
MCP_PORT=8001
QLAB_SCHEDULER=1

# Internal analytics account. setup.sh replaces this first-provision placeholder
# in the ignored .env. Dashboard changes persist in PostgreSQL and are not reset
# by later setup runs. The admin entry point is intentionally not public.
QUANTUMYOG_ADMIN_EMAIL=admin@localhost.test
QUANTUMYOG_ADMIN_PASSWORD=replace-with-generated-admin-password
LLM_SETTINGS_ENCRYPTION_KEY=replace-with-generated-fernet-key

# Local Kokoro powers live Sumi speech and optional media authoring. The app
# still serves committed narration when the local voice extras are absent.
KOKORO_API_URL=http://127.0.0.1:5152
KOKORO_VOICE=am_michael
KOKORO_SPEED=0.94
COMPANION_TTS_MODEL=hexgrad/Kokoro-82M
VOICE_HOST=127.0.0.1
VOICE_PORT=5152
VOICE_PRELOAD=1
# Set to 0 to run the platform without the optional live voice service.
VOICE_AUTOSTART=1
# Duplex WebSocket uses Silero when installed and falls back to energy VAD.
VOICE_VAD_PROVIDER=silero
VOICE_ENDPOINT_SILENCE_MS=600
VOICE_MIN_UTTERANCE_MS=250
VOICE_SILERO_THRESHOLD=0.60
VOICE_MIN_PCM_RMS=350
VOICE_MAX_NO_SPEECH_PROB=0.50
VOICE_MIN_AVG_LOGPROB=-1.0
VOICE_MIN_WORD_CONFIDENCE=0.55
COMFYUI_URL=http://127.0.0.1:8188
COMFYUI_CHECKPOINT=DreamShaper_8_pruned.safetensors
