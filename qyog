#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PYTHON_BIN="${PYTHON_BIN:-$ROOT/.venv/bin/python}"

if [[ -f "$ROOT/.env" ]]; then
  set -a
  # shellcheck disable=SC1091
  . "$ROOT/.env"
  set +a
fi

[[ -x "$PYTHON_BIN" ]] || {
  echo "QuantumYog virtual environment is missing. Run ./scripts/setup.sh first." >&2
  exit 1
}

cd "$ROOT"
exec "$PYTHON_BIN" -m app.cli "$@"
